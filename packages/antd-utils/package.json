{
  "name": "@highstack/antd-utils",
  "version": "0.1.0",
  "description": "Better Ant Design primitives — Zod-powered forms, imperative modals & drawers",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "antd": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "antd": "^5.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@types/react": "^19.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adityadewaskar/highstack",
    "directory": "packages/antd-utils"
  },
  "keywords": [
    "antd",
    "ant-design",
    "zod",
    "react",
    "form",
    "modal",
    "drawer",
    "hooks"
  ]
}
